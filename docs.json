{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "杖雍皓的Notes - 联合库UNHub支持",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "UNHub 联合库 知识中枢",
          "icon": "book-bookmark",
          "color": {
            "light": "#4cb3d4",
            "dark": "#4cb3d4"
          },
          "href": "https://docs.zyhorg.cn/"
        },
        {
          "anchor": "杖雍皓 Socialclub",
          "icon": "club",
          "href": "https://socialclub.zyhorg.cn/"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "hidden": true,
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "技术支持",
        "href": "mailto:info@zyhorg.cn"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/zyhgov"
    }
  },
  "description": "杖雍皓的Notes知识文档库，由联合库UNHub支持建设，发布杖雍皓（张永豪）的文档、知识与经验。",
  "fonts": {
    "family": "HarmonyOS_Sans_SC_Medium",
    "source": "https://cdn.jsdelivr.net/gh/irozhi/HarmonyOS-Sans/HarmonyOS_Sans_SC/HarmonyOS_Sans_SC_Medium.woff2",
    "format": "woff2"
  },
  "seo": {
    "indexing": "all"
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#f5f5f7",
      "dark": "#1d1d1f"
    }
  },
  "api": {
    "playground": {
      "proxy": true
    }
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "icons": {
    "library": "lucide"
  },
  "search": {
    "prompt": "输入关键词或提问..."
  }
}
